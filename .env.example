APP_PORT=3000
NODE_ENV=development
AUTH_USER=admin
AUTH_PASSWORD=change-me
AUTH_SESSION_SECRET=replace-with-long-random-string
# Set true only when service is opened via HTTPS.
AUTH_COOKIE_SECURE=false
DATABASE_URL=postgres://outreach:outreach@localhost:5432/outreach
POSTGRES_DB=outreach
POSTGRES_USER=outreach
POSTGRES_PASSWORD=outreach
POSTGRES_PORT=55432

PUBLIC_TRACKING_URL=
MAIL_DRY_RUN=true
ATTACHMENT_DIR=storage/attachments
MAX_ATTACHMENT_MB=50
DKIM_SELECTORS=mail,default,selector1,yandex

WORKER_POLL_MS=5000
INBOX_SYNC_INTERVAL_MINUTES=5
VALIDATION_BATCH_SIZE=100
